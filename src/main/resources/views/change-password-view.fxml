<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="14.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="cocoffee.controllers.ChangePasswordController"
      stylesheets="@../styles/style.css" prefWidth="380" prefHeight="380"
      maxWidth="380" maxHeight="380" styleClass="login-card">

    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <Label text="🔒" style="-fx-font-size: 30px;"/>
    <Label text="ĐỔI MẬT KHẨU" styleClass="title-text"/>
    <Label text="Cập nhật mật khẩu đăng nhập của bạn" styleClass="subtitle-text"/>

    <VBox spacing="12" style="-fx-padding: 8 0 0 0;">
        <PasswordField fx:id="oldPasswordField" promptText="Mật khẩu hiện tại"/>
        <PasswordField fx:id="newPasswordField" promptText="Mật khẩu mới (tối thiểu 6 ký tự)"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Nhập lại mật khẩu mới" onAction="#handleChangePassword"/>
    </VBox>

    <Button fx:id="submitButton" text="Đổi mật khẩu" styleClass="btn-primary"
            onAction="#handleChangePassword" prefWidth="Infinity"/>

    <Label fx:id="messageLabel" text="" wrapText="true" style="-fx-text-fill: #D32F2F;"/>
</VBox>
