<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<HBox spacing="18" xmlns:fx="http://javafx.com/fxml" fx:controller="cocoffee.controllers.HistoryController" stylesheets="@../styles/style.css" style="-fx-background-color: #F5F1EB;">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

    <fx:define>
        <ToggleGroup fx:id="filterModeGroup"/>
    </fx:define>

    <VBox spacing="14" HBox.hgrow="ALWAYS" prefWidth="620">

        <HBox spacing="14" alignment="CENTER_LEFT">
            <Button text="⬅" onAction="#handleBackToMain" styleClass="btn-secondary" style="-fx-background-color: #9E9E9E; -fx-padding: 8 14 8 14;"/>
            <Label text="📊 LỊCH SỬ HÓA ĐƠN &amp; DOANH THU" styleClass="title-text" style="-fx-font-size: 19px;"/>
        </HBox>

        <!-- ===== THẺ THỐNG KÊ ===== -->
        <HBox spacing="14" alignment="CENTER">
            <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="stat-card, stat-card-success">
                <Label text="💰 TỔNG DOANH THU" styleClass="stat-label"/>
                <Label fx:id="totalRevenueLabel" text="0 Đ" styleClass="stat-value"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="stat-card, stat-card-info">
                <Label text="✔ HÓA ĐƠN THÀNH CÔNG" styleClass="stat-label"/>
                <Label fx:id="successCountLabel" text="0" styleClass="stat-value"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="stat-card, stat-card-danger">
                <Label text="❌ HÓA ĐƠN ĐÃ HỦY" styleClass="stat-label"/>
                <Label fx:id="cancelCountLabel" text="0" styleClass="stat-value"/>
            </VBox>
        </HBox>

        <!-- ===== TÌM KIẾM / LỌC TRẠNG THÁI ===== -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="filter-bar">
            <TextField fx:id="searchField" promptText="🔍 Tìm mã HD / Số bàn..." prefWidth="220"/>
            <ComboBox fx:id="statusFilterComboBox" prefWidth="170" promptText="Tất cả trạng thái"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="↻ Làm mới" onAction="#handleResetFilters" style="-fx-background-color: #757575; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
        </HBox>

        <!-- ===== BỘ LỌC NGÀY / THÁNG / NĂM (segmented) + IN BÁO CÁO ===== -->
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="segmented-bar">
            <Label text="Xem doanh thu theo:" style="-fx-font-weight: bold; -fx-text-fill: #6D4C41;"/>

            <HBox styleClass="segmented-group">
                <ToggleButton fx:id="btnFilterDay" text="Ngày" toggleGroup="$filterModeGroup" selected="true" styleClass="segmented-toggle"/>
                <ToggleButton fx:id="btnFilterMonth" text="Tháng" toggleGroup="$filterModeGroup" styleClass="segmented-toggle"/>
                <ToggleButton fx:id="btnFilterYear" text="Năm" toggleGroup="$filterModeGroup" styleClass="segmented-toggle"/>
            </HBox>

            <DatePicker fx:id="datePicker" prefWidth="140" promptText="Chọn ngày"/>
            <ComboBox fx:id="monthComboBox" prefWidth="100" promptText="Chọn tháng" visible="false" managed="false"/>
            <ComboBox fx:id="yearComboBox" prefWidth="100" promptText="Chọn năm" visible="false" managed="false"/>

            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🖨️ In báo cáo doanh thu" onAction="#handlePrintRevenueReport" styleClass="btn-secondary" style="-fx-background-color: #00695C;"/>
        </HBox>

        <VBox styleClass="side-card" VBox.vgrow="ALWAYS">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <TableView fx:id="invoiceTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="Mã Hóa Đơn" prefWidth="150">
                        <cellValueFactory><PropertyValueFactory property="invoiceCode"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Vị trí/Bàn" prefWidth="90">
                        <cellValueFactory><PropertyValueFactory property="tableNumber"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colTotal" text="Tổng Tiền" prefWidth="110">
                        <cellValueFactory><PropertyValueFactory property="total"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colPaymentMethod" text="PTTT" prefWidth="100">
                        <cellValueFactory><PropertyValueFactory property="paymentMethod"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colStatus" text="Trạng Thái" prefWidth="130">
                        <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </VBox>
    </VBox>

    <VBox spacing="12" prefWidth="380" styleClass="side-card">
        <padding><Insets top="18" right="16" bottom="16" left="16"/></padding>

        <Label fx:id="detailsTitleLabel" text="CHI TIẾT HÓA ĐƠN" styleClass="title-text" style="-fx-font-size: 16px;"/>
        <Label fx:id="invoiceTimeLabel" text="Thời gian: --/--/----" style="-fx-font-size: 13px; -fx-text-fill: #8D6E63;"/>

        <TableView fx:id="detailTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="Tên món" prefWidth="160">
                    <cellValueFactory><PropertyValueFactory property="productName"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="SL" prefWidth="50">
                    <cellValueFactory><PropertyValueFactory property="quantity"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="colDetailTotal" text="Thành Tiền" prefWidth="120">
                    <cellValueFactory><PropertyValueFactory property="total"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <Button fx:id="reprintButton" text="🖨️ In lại hóa đơn" onAction="#handleReprintInvoice"
                maxWidth="Infinity" disable="true" styleClass="btn-primary" style="-fx-background-color: #F57F17;"/>
    </VBox>
</HBox>
