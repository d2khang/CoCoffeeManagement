<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="cocoffee.controllers.MainController"
      stylesheets="@../styles/style.css">

    <Label text="CỎ Coffee &amp; Tea" styleClass="title-text"/>

    <Label fx:id="statusLabel" text="Đang kiểm tra cơ sở dữ liệu..."/>

    <Button text="Bắt Đầu Bán Hàng" styleClass="btn-primary" onAction="#onStartButtonClick"/>
</VBox>