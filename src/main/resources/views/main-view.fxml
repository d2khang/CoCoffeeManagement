<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="cocoffee.controllers.MainController"
            stylesheets="@../styles/style.css" prefWidth="1280" prefHeight="720">

    <left>
        <VBox spacing="6" prefWidth="250" styleClass="sidebar">

            <!-- ===== VÙNG LOGO / AVATAR ===== -->
            <VBox alignment="CENTER" spacing="8" styleClass="sidebar-header">
                <StackPane>
                    <Circle radius="26" styleClass="sidebar-avatar"/>
                    <Label text="☕" style="-fx-font-size: 22px;"/>
                </StackPane>
                <Label text="CỎ Coffee" styleClass="sidebar-brand"/>
                <Label fx:id="statusLabel" text="Xin chào, Admin" styleClass="sidebar-user"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>

            <!-- ===== MENU CHÍNH ===== -->
            <VBox spacing="4" styleClass="sidebar-menu">
                <HBox styleClass="sidebar-item" alignment="CENTER_LEFT">
                    <Region fx:id="indicatorPos" styleClass="sidebar-indicator"/>
                    <Button text="🛒  Bán hàng (POS)" onAction="#loadPosView" styleClass="sidebar-btn" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox styleClass="sidebar-item" alignment="CENTER_LEFT">
                    <Region fx:id="indicatorMenu" styleClass="sidebar-indicator"/>
                    <Button text="🍹  Thực đơn" onAction="#loadMenuView" styleClass="sidebar-btn" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
                <HBox styleClass="sidebar-item" alignment="CENTER_LEFT">
                    <Region fx:id="indicatorHistory" styleClass="sidebar-indicator"/>
                    <Button text="📊  Lịch sử &amp; Doanh thu" onAction="#loadHistoryView" styleClass="sidebar-btn" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- ===== VÙNG DƯỚI CÙNG ===== -->
            <VBox spacing="8" styleClass="sidebar-footer">
                <Button text="🔒  Đổi mật khẩu" onAction="#onChangePasswordClick" styleClass="sidebar-btn-outline" maxWidth="Infinity"/>
                <Button text="🚪  Đăng xuất" onAction="#handleLogout" styleClass="sidebar-btn-danger" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <VBox alignment="CENTER" spacing="12">
                <Label text="👋" style="-fx-font-size: 42px;"/>
                <Label text="Chào mừng đến với hệ thống POS" styleClass="welcome-title"/>
                <Label text="Chọn một chức năng ở thanh bên trái để bắt đầu" styleClass="welcome-subtitle"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
