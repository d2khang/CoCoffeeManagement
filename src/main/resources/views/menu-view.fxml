<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="cocoffee.controllers.MenuController"
            stylesheets="@../styles/style.css" style="-fx-background-color: #F5F1EB;">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <top>
        <VBox alignment="CENTER" spacing="4" styleClass="login-card">
            <padding><Insets top="20" bottom="20"/></padding>
            <Label text="QUẢN LÝ THỰC ĐƠN" styleClass="title-text"/>
            <Label text="Thêm, chỉnh sửa và quản lý danh sách đồ uống" styleClass="subtitle-text"/>
            <BorderPane.margin><Insets bottom="15"/></BorderPane.margin>
        </VBox>
    </top>

    <left>
        <VBox spacing="14" prefWidth="260" styleClass="side-card">
            <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>

            <Label text="Thông tin món" styleClass="section-label"/>

            <TextField fx:id="nameField" promptText="Tên đồ uống (VD: Cà phê sữa)"/>
            <ComboBox fx:id="categoryComboBox" promptText="Chọn danh mục" prefWidth="Infinity"/>
            <TextField fx:id="priceField" promptText="Giá tiền (VNĐ)"/>
            <ComboBox fx:id="statusComboBox" promptText="Trạng thái" prefWidth="Infinity"/>

            <HBox spacing="8">
                <Button text="Thêm" styleClass="btn-primary" onAction="#handleAddProduct"/>
                <Button text="Sửa" styleClass="btn-secondary" onAction="#handleUpdateProduct"/>
                <Button text="Xóa" styleClass="btn-danger" onAction="#handleDeleteProduct"/>
            </HBox>

            <Label fx:id="messageLabel" text="" wrapText="true" style="-fx-text-fill: #D32F2F; -fx-font-size: 12px;"/>
        </VBox>
    </left>

    <center>
        <TableView fx:id="productTable">
            <BorderPane.margin>
                <Insets top="18" right="0" bottom="0" left="18"/>
            </BorderPane.margin>
            <columns>
                <TableColumn text="ID" prefWidth="50">
                    <cellValueFactory><PropertyValueFactory property="id"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="Tên Món" prefWidth="200">
                    <cellValueFactory><PropertyValueFactory property="name"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="priceColumn" text="Giá (VNĐ)" prefWidth="120">
                    <cellValueFactory><PropertyValueFactory property="price"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="120">
                    <cellValueFactory><PropertyValueFactory property="status"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>
    </center>
</BorderPane>