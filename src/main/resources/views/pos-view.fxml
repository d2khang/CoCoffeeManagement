<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<HBox spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="cocoffee.controllers.PosController" stylesheets="@../styles/style.css">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="450">
        <HBox spacing="20" alignment="CENTER_LEFT">
            <Button text="⬅ Quay lại" onAction="#handleBackToMain" style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Label text="THỰC ĐƠN" styleClass="title-text"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Lọc danh mục:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="categoryComboBox" promptText="Tất cả đồ uống" prefWidth="200"/>
        </HBox>
        <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="Tên Đồ Uống" prefWidth="220">
                    <cellValueFactory><PropertyValueFactory property="name"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="menuPriceColumn" text="Giá Tiền" prefWidth="120">
                    <cellValueFactory><PropertyValueFactory property="price"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Label text="Số lượng:"/>
            <TextField fx:id="qtyField" text="1" prefWidth="50" alignment="CENTER"/>
            <Button text="Thêm Vào Hóa Đơn ➔" styleClass="btn-primary" onAction="#handleAddToCart"/>
        </HBox>
    </VBox>

    <VBox spacing="10" HBox.hgrow="ALWAYS" prefWidth="400" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">
        <Label fx:id="currentInvoiceLabel" text="CHƯA CHỌN HÓA ĐƠN" styleClass="title-text" style="-fx-font-size: 18px; -fx-text-fill: #1565C0;"/>
        <TableView fx:id="cartTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="Tên món" prefWidth="160">
                    <cellValueFactory><PropertyValueFactory property="productName"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="SL" prefWidth="50">
                    <cellValueFactory><PropertyValueFactory property="quantity"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="cartTotalColumn" text="Thành Tiền" prefWidth="120"/>
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER">
            <Button text="Xóa món" style="-fx-background-color: #D32F2F; -fx-text-fill: white;" onAction="#handleRemoveFromCart"/>
            <Button text="Lưu Tạm" style="-fx-background-color: #F57C00; -fx-text-fill: white;" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#handleSaveInvoice"/>
        </HBox>
        <Separator/>
        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Label text="TỔNG TIỀN:" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label fx:id="totalAmountLabel" text="0 Đ" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #D32F2F;"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER">
            <ComboBox fx:id="paymentMethodComboBox" promptText="Phương thức" prefWidth="120"/>
            <Button text="THANH TOÁN" styleClass="btn-primary" style="-fx-font-size: 16px; -fx-background-color: #2E7D32;" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#handleCheckout"/>
        </HBox>
        <Label fx:id="messageLabel" text="" wrapText="true" alignment="CENTER" maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="10" prefWidth="250" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">
        <Label text="HÓA ĐƠN CHỜ (OPEN)" styleClass="title-text" style="-fx-font-size: 16px;"/>
        <ListView fx:id="openInvoicesListView" VBox.vgrow="ALWAYS"/>
        <Button text="+ TẠO HÓA ĐƠN MỚI" style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" maxWidth="Infinity" onAction="#handleCreateNewInvoice"/>
    </VBox>
</HBox>