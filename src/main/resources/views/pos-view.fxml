<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<HBox spacing="16" xmlns:fx="http://javafx.com/fxml" fx:controller="cocoffee.controllers.PosController" stylesheets="@../styles/style.css" style="-fx-background-color: #F5F1EB;">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

    <!-- ============ CỘT 1: THỰC ĐƠN ============ -->
    <VBox spacing="12" HBox.hgrow="ALWAYS" prefWidth="440" styleClass="side-card">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <HBox spacing="14" alignment="CENTER_LEFT">
            <Button text="⬅" onAction="#handleBackToMain" styleClass="btn-secondary" style="-fx-background-color: #9E9E9E; -fx-padding: 8 14 8 14;"/>
            <Label text="🍹 THỰC ĐƠN" styleClass="title-text" style="-fx-font-size: 20px;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="productSearchField" promptText="🔍 Tìm món nhanh (Enter)..." HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="categoryComboBox" promptText="Tất cả danh mục" prefWidth="160"/>
        </HBox>

        <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="Tên Đồ Uống" prefWidth="230">
                    <cellValueFactory><PropertyValueFactory property="name"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="menuPriceColumn" text="Giá Tiền" prefWidth="130">
                    <cellValueFactory><PropertyValueFactory property="price"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="qty-bar">
            <Label text="Số lượng:" style="-fx-font-weight: bold; -fx-text-fill: #6D4C41;"/>
            <TextField fx:id="qtyField" text="1" prefWidth="55" alignment="CENTER"/>
            <Button text="Thêm vào hóa đơn  ➔" styleClass="btn-primary" onAction="#handleAddToCart"/>
        </HBox>
    </VBox>

    <!-- ============ CỘT 2: GIỎ HÀNG / HÓA ĐƠN HIỆN TẠI ============ -->
    <VBox spacing="12" HBox.hgrow="ALWAYS" prefWidth="420" styleClass="side-card">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

        <Label fx:id="currentInvoiceLabel" text="CHƯA CHỌN HÓA ĐƠN" styleClass="status-badge"/>

        <TableView fx:id="cartTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn text="Tên món" prefWidth="170">
                    <cellValueFactory><PropertyValueFactory property="productName"/></cellValueFactory>
                </TableColumn>
                <TableColumn text="SL" prefWidth="45">
                    <cellValueFactory><PropertyValueFactory property="quantity"/></cellValueFactory>
                </TableColumn>
                <TableColumn fx:id="cartTotalColumn" text="Thành Tiền" prefWidth="130">
                    <cellValueFactory><PropertyValueFactory property="total"/></cellValueFactory>
                </TableColumn>
            </columns>
        </TableView>

        <HBox spacing="8" alignment="CENTER">
            <Button text="🗑 Xóa món" styleClass="btn-danger" onAction="#handleRemoveFromCart"/>
            <Button text="⏸ Chờ thanh toán" styleClass="btn-warning" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#handleSaveInvoice"/>
            <Button text="✖ Hủy giao dịch" styleClass="btn-danger" onAction="#handleVoidInvoice"/>
        </HBox>

        <Separator/>

        <HBox alignment="CENTER_RIGHT" spacing="14" styleClass="total-row">
            <Label text="TỔNG TIỀN" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #6D4C41;"/>
            <Label fx:id="totalAmountLabel" text="0 Đ" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #D32F2F;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <ComboBox fx:id="paymentMethodComboBox" promptText="Phương thức" prefWidth="140"/>
            <Button text="✔ XÁC NHẬN THANH TOÁN" styleClass="btn-success" style="-fx-font-size: 15px;" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#handleCheckout"/>
        </HBox>
        <Label fx:id="messageLabel" text="" wrapText="true" alignment="CENTER" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-padding: 4 0 0 0;"/>
    </VBox>

    <!-- ============ CỘT 3: HÓA ĐƠN CHỜ ============ -->
    <VBox spacing="12" prefWidth="280" styleClass="side-card">
        <padding><Insets top="18" right="16" bottom="18" left="16"/></padding>

        <Label text="📋 HÓA ĐƠN CHỜ" styleClass="title-text" style="-fx-font-size: 16px;"/>

        <TextField fx:id="invoiceSearchField" promptText="🔍 Tìm hóa đơn (mã/bàn)..."/>

        <ListView fx:id="openInvoicesListView" VBox.vgrow="ALWAYS" styleClass="invoice-list"/>

        <HBox spacing="8">
            <ComboBox fx:id="tableSelectionComboBox" prefWidth="120" promptText="Chọn bàn..."/>
            <Button text="+ TẠO MỚI" styleClass="btn-primary" style="-fx-font-size: 13px;" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#handleCreateNewInvoice"/>
        </HBox>
    </VBox>
</HBox>
